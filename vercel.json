{
    "functions": {
        "api/proxy.js": {
            "runtime": "nodejs18.x"
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api/proxy.js" }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        }
    ]
}
